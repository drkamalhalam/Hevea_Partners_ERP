# ============================================================
# Hevea Partners ERP — Environment Variables Reference
# Copy to .env and fill in values before running locally.
# In Replit, set these via the Secrets panel (never commit .env).
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string. Provisioned automatically in Replit.
# For self-hosted: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/hevea_partners

# ── Authentication (Clerk) ───────────────────────────────────
# For local dev without Clerk, set MOCK_AUTH=true.
# In this mode, the app uses a Local Persona selector.
MOCK_AUTH=true

# If not using mock auth, supply these from Clerk dashboard:
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Exposed to the frontend Vite build (must be prefixed VITE_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional: production Clerk proxy URL (auto-set in production)
# VITE_CLERK_PROXY_URL=https://your-domain.com/api/__clerk

# ── Session ───────────────────────────────────────────────────
# Random secret used for session signing. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-secret

# ── Object Storage (Replit GCS sidecar) ──────────────────────
# For local dev without Google Cloud Storage, set MOCK_STORAGE=true.
# In this mode, files are saved locally on disk under the ./uploads directory.
MOCK_STORAGE=true

DEFAULT_OBJECT_STORAGE_BUCKET_ID=local-mock-bucket
PRIVATE_OBJECT_DIR=private
PUBLIC_OBJECT_SEARCH_PATHS=public

# Replit GCS sidecar local endpoint (token + credential service).
# Only override this if deploying outside Replit.
# Default: http://127.0.0.1:1106
# REPLIT_SIDECAR_ENDPOINT=http://127.0.0.1:1106

# ── Runtime (set automatically by Replit workflows) ──────────
# Do not set manually — the workflow system injects these.
# PORT=8080          (API server)
# PORT=23087         (Frontend Vite dev server)
# BASE_PATH=/        (URL base path for the frontend artifact)

# ── Node environment ─────────────────────────────────────────
NODE_ENV=development
# Set to "production" in deployment to enable:
#   - Clerk proxy middleware
#   - No dev-only Vite plugins
